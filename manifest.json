{
  "manifest_version": 3,
  "name": "Solstice",
  "version": "1.0.1",
  "description": "A calm new tab that visualizes daylight and working hours across all your time zones, at a glance.",
  "author": "Sean Oliver",
  "homepage_url": "https://github.com/seanoliver/solstice",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["geolocation"],
  "host_permissions": [
    "https://api.bigdatacloud.net/*",
    "https://ipwho.is/*",
    "https://ipapi.co/*",
    "https://get.geojs.io/*",
    "https://geocoding-api.open-meteo.com/*"
  ],
  "chrome_url_overrides": { "newtab": "newtab.html" }
}
